# =============================================================================
# BaW OS — variables de entorno
# =============================================================================
# Copia este archivo a `.env.local` y completa con valores reales.
# En Vercel se configuran en Project Settings → Environment Variables.
# Las variables marcadas (cliente) se exponen al navegador (NEXT_PUBLIC_*).
# Todas las demás son servidor-only.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (REQUERIDO — sin esto la app no arranca)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe — pagos en línea (Mateos: opcional, pagos vía SPEI también)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# WhatsApp Business API (Meta Cloud API) — REQUERIDO para intake conversacional
# -----------------------------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=baw-os-webhook-2026
# Gate maestro del envío automático de cobranza por WhatsApp. Mientras esté
# vacío/false, el cron de cobranza corre en dry-run (registra, NO envía).
# Ponlo en 'true' cuando las credenciales de arriba estén listas y quieras
# que los recordatorios y avisos de mora se envíen de verdad a los inquilinos.
COBRANZA_WHATSAPP_ENABLED=false

# -----------------------------------------------------------------------------
# Channex — channel manager (corto plazo / STR). Opcional para Mateos LTR puro.
# -----------------------------------------------------------------------------
CHANNEX_API_URL=https://api.channex.io
CHANNEX_API_KEY=

# -----------------------------------------------------------------------------
# Mifiel — firma digital de contratos
# Hoy oculto en UI hasta confirmar credenciales productivas (ver Sprint 1).
# Activar con NEXT_PUBLIC_MIFIEL_ENABLED=true cuando esté listo.
# -----------------------------------------------------------------------------
MIFIEL_APP_ID=
MIFIEL_APP_SECRET=
MIFIEL_API_URL=https://app.mifiel.com/api/v1
NEXT_PUBLIC_MIFIEL_ENABLED=false

# -----------------------------------------------------------------------------
# FacturAPI — CFDI / facturación electrónica SAT
# Hoy oculto el banner CTA. Activar con NEXT_PUBLIC_SHOW_FACTURAPI_CTA=true.
# -----------------------------------------------------------------------------
FACTURAPI_SECRET_KEY=
NEXT_PUBLIC_SHOW_FACTURAPI_CTA=false

# -----------------------------------------------------------------------------
# Groq — LLM para clasificación de mensajes WhatsApp
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Portales públicos — autenticación por token corto
# -----------------------------------------------------------------------------
# OWNER_TOKEN: token de un solo uso para login propietario en /owner
OWNER_TOKEN=
# CONSERJE_PIN: PIN de acceso del conserje al kiosco /conserje (4-6 dígitos)
# Importante: mover de hardcode "1234" a este env antes de producción.
CONSERJE_PIN=

# -----------------------------------------------------------------------------
# Agent Interface (Tier 2) — autenticación de agentes que llaman APIs internas
# -----------------------------------------------------------------------------
# LEGACY: key global en transición a credenciales por-agente (agent_credentials).
# Generar un valor aleatorio propio; el valor histórico "baw-secret-2026" está
# comprometido (estuvo embebido en JS del cliente) y NO debe reutilizarse.
BAWOS_API_KEY=

# -----------------------------------------------------------------------------
# Webhooks entrantes — verificación de firma/secreto (audit 2026-07 / PR #134)
# -----------------------------------------------------------------------------
# WHATSAPP_APP_SECRET: App Secret de la app de Meta. Sin esto el webhook de
# WhatsApp responde 200 pero NO procesa mensajes (fail-safe).
WHATSAPP_APP_SECRET=
# MIFIEL_WEBHOOK_SECRET: secreto compartido; configurar la URL del webhook en
# Mifiel como /api/mifiel/webhook?secret=<valor> (o header x-webhook-secret).
MIFIEL_WEBHOOK_SECRET=
# CHANNEX_WEBHOOK_SECRET: token compartido en la URL del webhook de Channex
# (/api/channex/webhook?org=<slug>&token=<valor>).
CHANNEX_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Agentes third-party vía Discord (Sprint 5A — Alicia + pipeline /process)
# -----------------------------------------------------------------------------
# DISCORD_PUBLIC_KEY: public key ed25519 de la app de Discord (verifica firmas).
DISCORD_PUBLIC_KEY=
# INTERNAL_WEBHOOK_SECRET: bearer entre /api/agents/discord-interactions y su
# worker /process. Sin esto, /process devuelve 401 siempre.
INTERNAL_WEBHOOK_SECRET=
# ALICIA_WEBHOOK_URL: URL del skill de Alicia (tunnel Cloudflare) para push.
ALICIA_WEBHOOK_URL=
# DISCORD_DEFAULT_ORG_ID: org a la que se atribuyen interacciones Discord
# (MVP single-org; mapeo guild→org multi-tenant es follow-up).
DISCORD_DEFAULT_ORG_ID=

# -----------------------------------------------------------------------------
# Cron jobs — Vercel Cron protege endpoints internos con este secreto
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Multi-tenant (single-tenant hoy: Mateos / Frontier Bay)
# -----------------------------------------------------------------------------
# ORG_ID hardcodeado en código en 12 archivos. Pendiente de migración a env.
# DEFAULT_ORG_ID=ed4308c7-2bdb-46f2-be69-7c59674838e2

# -----------------------------------------------------------------------------
# Public listing / booking (Fase 1 — /edificios/[buildingSlug], ADR-017)
# -----------------------------------------------------------------------------
# Feature flag server-side de la API pública /api/public/v1/*.
PUBLIC_BOOKING_ENABLED=false
# Feature flag client/SSR del grupo de rutas (public-booking). Ambos deben
# estar en true para que el sitio público funcione.
NEXT_PUBLIC_PUBLIC_BOOKING_ENABLED=false
# Dominio público (sitemap, OG, redirects de Stripe). Sin scheme final slash.
NEXT_PUBLIC_SITE_URL=https://baw.mx
# Overrides opcionales de las URLs de retorno de Stripe Checkout. Si se omiten
# se construyen como NEXT_PUBLIC_SITE_URL/edificios/<slug>/confirmacion/<hold>.
# PUBLIC_BOOKING_SUCCESS_URL=
# PUBLIC_BOOKING_CANCEL_URL=
# Webhook secret del flujo público de Stripe (aislado del interno, ADR-018).
# STRIPE_WEBHOOK_SECRET_PUBLIC=

# -----------------------------------------------------------------------------
# Landing informativa baw.mx (Fase 1.5 PR B)
# -----------------------------------------------------------------------------
# Org a la que se registran los leads de la lista de interés ("¿Operas
# propiedades?"). Fallback: DISCORD_DEFAULT_ORG_ID. Sin ninguna de las dos,
# el formulario cae a mailto:admin@baw.mx.
# MARKETING_LEADS_ORG_ID=
